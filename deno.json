{
  "tasks": {
    "dev:root": "deno run --allow-read --allow-write --allow-env src/main.ts",
    "fmt": "deno fmt deno.json src tests",
    "fmt:check": "deno fmt --check deno.json src tests",
    "lint": "deno lint src tests",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-run=git src tests",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1"
  },
  "exclude": [
    ".test-tmp/**",
    "documentation/notes/**"
  ],
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "documentation/notes/**",
      "**/*.md"
    ]
  }
}
