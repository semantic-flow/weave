{
  "tasks": {
    "dev:root": "deno run --allow-read --allow-write --allow-env src/main.ts",
    "fmt": "deno fmt deno.json src tests",
    "fmt:check": "deno fmt --check deno.json src tests",
    "lint": "deno lint src tests",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "test": "WEAVE_GENERATED_AT=2026-05-03T00:00:00.000Z deno test --allow-read --allow-write --allow-run=git,deno --allow-env src tests",
    "test:coverage": "WEAVE_GENERATED_AT=2026-05-03T00:00:00.000Z deno test --allow-read --allow-write --allow-run=git,deno --allow-env --coverage=coverage src tests",
    "coverage:lcov": "deno coverage --lcov --output=coverage/lcov.info --exclude='^file:.*/dependencies/' --exclude='^file:.*/tests/' coverage",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "jsonld": "npm:jsonld@9.0.0",
    "n3": "npm:n3@2.0.3",
    "rdf-canonize": "npm:rdf-canonize@5.0.0"
  },
  "exclude": [
    ".test-tmp/**",
    "documentation/notes/**"
  ],
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "documentation/notes/**",
      "**/*.md"
    ]
  }
}
