{
  "version": "0.2.2",
  "tasks": {
    "dev:root": "deno run --allow-read --allow-write --allow-env --allow-net src/main.ts",
    "bump:version": "deno run --allow-read --allow-write scripts/bump-version.ts",
    "build:binaries": "deno run --allow-read --allow-write --allow-run=deno scripts/build-binaries.ts",
    "package:binaries": "deno run --allow-read --allow-write scripts/package-binaries.ts",
    "assemble:npm-packages": "deno run --allow-read --allow-write scripts/assemble-npm-packages.ts",
    "smoke:npm-install": "deno run --allow-read --allow-write --allow-run --allow-env scripts/smoke-npm-install.ts",
    "publish:npm-packages": "deno run --allow-read --allow-write --allow-run --allow-env scripts/publish-npm-packages.ts",
    "fixture:ladder": "deno run --allow-read --allow-write --allow-run=git,deno --allow-env scripts/fixture-ladder.ts",
    "coverage:prepare": "deno run --allow-write=/tmp/semantic-flow-coverage scripts/prepare-coverage-dir.ts",
    "coverage:junit:codecov": "deno run --allow-read=/tmp/semantic-flow-coverage --allow-write=/tmp/semantic-flow-coverage scripts/normalize-deno-junit.ts",
    "codecov:test-results": "deno task coverage:prepare && deno run --allow-read=/tmp/semantic-flow-coverage --allow-run=codecovcli,codecov --allow-env=CODECOV_TOKEN_SEMANTIC_FLOW,CODECOV_TOKEN,CODECOV_TEST_RESULTS_FLAGS,CODECOV_TEST_RESULTS_NAME scripts/upload-codecov-test-results.ts",
    "test:analytics": "deno run --allow-read=/tmp/semantic-flow-coverage --allow-write=/tmp/semantic-flow-coverage --allow-run=deno,codecovcli,codecov --allow-env=CODECOV_TOKEN_SEMANTIC_FLOW,CODECOV_TOKEN,CODECOV_TEST_RESULTS_FLAGS,CODECOV_TEST_RESULTS_NAME scripts/run-codecov-test-analytics.ts",
    "fmt": "deno fmt deno.json scripts src tests",
    "fmt:check": "deno fmt --check deno.json scripts src tests",
    "lint": "deno lint scripts src tests",
    "check": "deno check scripts/**/*.ts src/**/*.ts tests/**/*.ts",
    "test": "deno test --preload=tests/support/test_tmp_harness.ts --allow-read --allow-write --allow-run=git,deno --allow-env src tests",
    "test:coverage": "deno run --allow-read=/tmp/semantic-flow-coverage --allow-write=/tmp/semantic-flow-coverage --allow-run=deno --allow-env scripts/run-coverage-tests.ts",
    "coverage:lcov": "deno task coverage:prepare && deno coverage --lcov --output=/tmp/semantic-flow-coverage/lcov.info --exclude='^file:.*/dependencies/' --exclude='^file:.*/tests/' --exclude='^file:.*/\\.test-tmp/' --exclude='^file:.*/\\.cache/deno/' /tmp/semantic-flow-coverage",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test:coverage && deno task coverage:lcov"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "jsonld": "npm:jsonld@9.0.0",
    "n3": "npm:n3@2.0.3",
    "rdf-canonize": "npm:rdf-canonize@5.0.0",
    "shiki": "npm:shiki@4.0.2"
  },
  "exclude": [
    ".test-tmp/**",
    "documentation/notes/**",
    "**/*.md"
  ],
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "documentation/notes/**",
      "**/*.md"
    ]
  }
}
