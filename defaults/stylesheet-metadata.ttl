@base <https://semantic-flow.github.io/weave/defaults/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix sfcfg: <https://semantic-flow.github.io/sflo/config/> .

<stylesheet-metadata> a sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <stylesheet-metadata.ttl> .

<stylesheet-metadata.ttl> a sflo:LocatedFile, sflo:RdfDocument .

<stylesheet> a sfcfg:ResourcePageStylesheet, sflo:DigitalArtifact ;
  sflo:hasWorkingLocatedFile <stylesheet.css> .

<stylesheet.css> a sflo:LocatedFile .
